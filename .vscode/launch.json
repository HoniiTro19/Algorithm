{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "LLDB · 任意可执行",
      "type": "cppdbg",
      "request": "launch",
      "MIMode": "lldb",
      "program": "${input:programPath}",
      "args": ["${input:programArgs}"],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": true,
      "console": "${input:debugConsole}",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for lldb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "logging": {
        "engineLogging": false,
        "trace": false,
        "programOutput": true
      }
    },
    {
      "name": "GDB · 任意可执行",
      "type": "cppdbg",
      "request": "launch",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "program": "${input:programPath}",
      "args": ["${input:programArgs}"],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": true,
      "console": "${input:debugConsole}",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "logging": {
        "engineLogging": false,
        "trace": false,
        "programOutput": true
      }
    }
  ],
  "inputs": [
    {
      "id": "programPath",
      "type": "promptString",
      "description": "可执行文件路径（例如：${workspaceFolder}/build/src/lru/lruTest）",
      "default": "${workspaceFolder}/build/src/lru/lruTest"
    },
    {
      "id": "programArgs",
      "type": "promptString",
      "description": "程序参数（例如：--gtest_filter=LRUCache.solution；不需要就留空）",
      "default": ""
    },
    {
      "id": "debugConsole",
      "type": "pickString",
      "description": "程序 stdin/stdout 使用的终端（仅此一项与「集成 / 外部」有关）",
      "options": [
        {
          "label": "集成终端（输出在 VS Code）",
          "value": "integratedTerminal"
        },
        {
          "label": "外部系统终端（适合 cin、getline 等交互）",
          "value": "externalTerminal"
        }
      ],
      "default": "integratedTerminal"
    }
  ]
}
